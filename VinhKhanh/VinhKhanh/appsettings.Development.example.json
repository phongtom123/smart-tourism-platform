{
  "ConnectionStrings": {
    "DefaultConnection": "Server=127.0.0.1;Port=3306;Database=gianhang;Uid=root;Pwd=;"
  },
  "AccessControl": {
    "SessionMinutes": 30
  },
  "PAYOS_WEBHOOK_URL": "https://your-ngrok-domain.example/api/payment_webhook.php",
  "Email": {
    "SmtpHost": "smtp.office365.com",
    "SmtpPort": 587,
    "EnableSsl": true,
    "Username": "your-outlook@outlook.com",
    "Password": "YOUR_OUTLOOK_APP_PASSWORD_OR_SMTP_PASSWORD",
    "FromEmail": "your-outlook@outlook.com",
    "FromName": "Vinh Khanh Smart Tourism"
  },
  "Payment": {
    "WebhookSecurityKey": "replace-with-internal-webhook-secret",
    "VietQr": {
      "BankBin": "970000",
      "BankAccountNo": "REPLACE_WITH_BANK_ACCOUNT_NO",
      "BankAccountName": "REPLACE_WITH_BANK_ACCOUNT_NAME"
    },
    "PayOS": {
      "Endpoint": "https://api-merchant.payos.vn",
      "ClientId": "replace-with-payos-client-id",
      "ApiKey": "replace-with-payos-api-key",
      "ChecksumKey": "replace-with-payos-checksum-key",
      "ReturnUrl": "https://your-ngrok-domain.example/payos/return",
      "CancelUrl": "https://your-ngrok-domain.example/payos/cancel",
      "WebhookSecurityKey": "replace-with-payos-webhook-secret",
      "SignatureHeader": "X-PAYOS-SIGNATURE",
      "SignatureAlgorithm": "HMAC-SHA256"
    }
  }
}
